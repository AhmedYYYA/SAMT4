+}
+
+.station-stage__subtitle {
+  font-size: .84rem;
+  line-height: 1.55;
+}
+
+.station-stage__body {
+  font-size: 1rem;
+  line-height: 1.72;
+}
+
+.station-stage__meta span {
+  font-size: .74rem;
+  line-height: 1.35;
+}
+
+.station-stage__meta strong {
+  font-size: .9rem;
+  line-height: 1.35;
+}
+
+.station-stage__content li {
+  font-size: .9rem;
+  line-height: 1.55;
+}
+
+/* Competencies, assessment, governance and impact */
+.competency-card > span {
+  font-size: .9rem;
+}
+
+.competency-card p,
+.assessment-flow p,
+.impact-card p {
+  font-size: .9rem;
+  line-height: 1.65;
+}
+
+.assessment-flow h3,
+.impact-card h3,
+.impact-projects__list strong {
+  font-size: .88rem;
+  line-height: 1.4;
+}
+
+.assessment-flow article > span,
+.impact-projects__list span {
+  font-size: .8rem;
+}
+
+.governance-map__core strong {
+  font-size: 1rem;
+  line-height: 1.35;
+}
+
+.governance-map__core span {
+  font-size: .78rem;
+  line-height: 1.4;
+}
+
+.governance-map__node {
+  min-width: 12rem;
+  padding: .78rem 1.1rem;
+  font-size: .82rem;
+  line-height: 1.35;
+}
+
+.impact-projects__intro span {
+  font-size: .74rem;
+}
+
+/* Footer */
+.site-footer__statement span,
+.site-footer__bottom,
+.site-footer__disclaimer {
+  font-size: .8rem;
+  line-height: 1.6;
+}
+
+.site-footer__disclaimer {
+  color: #8792a2;
+}
+
+/* Dialogs and custom pop-ups */
+dialog.modal {
+  width: min(96vw, 1200px);
+  max-height: 92svh;
+  overflow: hidden;
+}
+
+.modal__shell {
+  max-height: 92svh;
+  padding: clamp(1.75rem, 4vw, 3.5rem);
+  scrollbar-gutter: stable;
+}
+
+.modal__shell--wide {
+  width: min(96vw, 1200px);
+}
+
+.modal__close {
+  width: 3rem;
+  height: 3rem;
+  font-size: 1.55rem;
+}
+
+.modal__brand {
+  font-size: .78rem;
+  line-height: 1.4;
+}
+
+.modal__brand img {
+  width: 3.8rem;
+  height: 3.2rem;
+}
+
+.modal__lead,
+.modal__grid--programme p,
+.admission-modal__grid > div > p {
+  font-size: 1rem;
+  line-height: 1.78;
+}
+
+.modal__grid--programme blockquote {
+  font-size: 1.05rem;
+}
+
+.modal__grid--programme li span,
+.admission-modal__grid li span {
+  font-size: .82rem;
+}
+
+.modal__grid--programme li strong,
+.admission-modal__grid li strong {
+  font-size: .88rem;
+  line-height: 1.4;
+}
+
+.selection-modal__grid h3,
+.station-modal__grid h3,
+.assessment-modal__grid h3 {
+  font-size: .9rem;
+  line-height: 1.4;
+}
+
+.selection-modal__grid p,
+.assessment-modal__grid p,
+.station-modal__grid li,
+.impact-modal__list li,
+.competency-modal__evidence li {

+/* ========================================================================== 
+   PHASE 3 — FINAL PRODUCTION READABILITY, ASSET & VIEWPORT PATCH
+   ========================================================================== */
+:root {
+  --text-xs: .75rem;
+  --text-sm: .875rem;
+  --text-base: 1rem;
+  --text-lg: 1.125rem;
+  --text-xl: 1.25rem;
+  --content-leading: 1.72;
+}
+
+body {
+  font-size: var(--text-base);
+  line-height: 1.55;
+}
+
+html[dir="rtl"] body {
+  font-size: 1.035rem;
+  line-height: 1.7;
+}
+
+.sr-only {
+  position: absolute !important;
+  width: 1px !important;
+  height: 1px !important;
+  padding: 0 !important;
+  margin: -1px !important;
+  overflow: hidden !important;
+  clip: rect(0, 0, 0, 0) !important;
+  white-space: nowrap !important;
+  border: 0 !important;
+}
+
+/* Brand assets */
+.loader__mark img,
+.brand-lockup__symbol,
+.mobile-menu__top img,
+.modal__brand img {
+  object-fit: contain;
+  object-position: center;
+}
+
+.brand-lockup__symbol {
+  width: 3.55rem;
+  height: 3rem;
+  flex: 0 0 auto;
+}
+
+.brand-lockup__text strong {
+  font-size: 1.15rem;
+}
+
+.brand-lockup__text small {
+  font-size: .68rem;
+  line-height: 1.4;
+  letter-spacing: .025em;
+}
+
+.desktop-nav a {
+  font-size: .72rem;
+  letter-spacing: .105em;
+}
+
+/* Global typography floor */
+.eyebrow,
+.micro-label {
+  font-size: clamp(.72rem, .76vw, .82rem);
+  line-height: 1.45;
+}
+
+.button {
+  min-height: 3.45rem;
+  padding: .95rem 1.4rem;
+  font-size: .76rem;
+  line-height: 1.2;
+}
+
+html[dir="rtl"] .button {
+  font-size: .94rem;
+}
+
+.text-link {
+  font-size: .78rem;
+  line-height: 1.35;
+}
+
+.loader__message,
+.loader__value,
+.cursor-label,
+.section-rail__current,
+.scroll-cue {
+  font-size: .75rem;
+}
+
+.hero__summary,
+.programme__statement > p,
+.stations__header > p,
+.competencies__header > p,
+.assessment__intro > p:not(.eyebrow),
+.impact__header > p,
+.admission__copy > p {
+  font-size: clamp(1rem, 1.12vw, 1.14rem);
+  line-height: var(--content-leading);
+}
+
+.programme__statement blockquote {
+  font-size: clamp(1.05rem, 1.35vw, 1.3rem);
+  line-height: 1.7;
+}
+
+.programme__metrics article span,
+.admission__criteria span {
+  font-size: .82rem;
+  line-height: 1.45;
+}
+
+.journey-card h3 {
+  font-size: clamp(1.35rem, 2vw, 2rem);
+}
+
+.journey-card p {
+  font-size: .94rem;
+  line-height: 1.65;
+}
+
+.selection-orbit__core span {
+  font-size: .78rem;
+  line-height: 1.45;
+}
+
+.selection-orbit__item {
+  font-size: .76rem;
+  line-height: 1.25;
+}
+
+.selection-gates h3 {
+  font-size: .92rem;
+}
+
+.selection-gates p {
+  font-size: .92rem;
+  line-height: 1.68;
+}
+
+/* Preparation stations — preserve complete approved SVG artwork */
+.station-console {
+  padding: 1.05rem;
+}
+
+.station-route__node {
+  min-width: 4.4rem;
+  min-height: 3.75rem;
+}
+
+.station-route__node span {
+  width: 2rem;
+  height: 2rem;
+  font-size: .66rem;
+}
+
+.station-route__node strong {
+  font-size: .7rem;
+  letter-spacing: .09em;
+}
+
+.station-stage {
+  grid-template-columns: minmax(0, 1.58fr) minmax(21rem, .78fr);
+  align-items: stretch;
+}
+
+.station-stage__visual {
+  aspect-ratio: 1672 / 941;
+  min-height: 0;
+  display: grid;
+  place-items: center;
+  isolation: isolate;
+  background:
+    radial-gradient(circle at 50% 45%, rgba(20, 44, 77, .34), transparent 65%),
+    #020711;
+}
+
+.station-stage__visual img {
+  width: 100%;
+  height: 100%;
+  object-fit: contain;
+  object-position: center;
+  background: #020711;
+}
+
+.station-stage__visual-overlay {
